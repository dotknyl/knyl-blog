---
import BaseLayout from "../layouts/BaseLayout.astro";
import TimeLineElement from "../components/cv/TimeLine.astro";

let arr = [
  {
    title: `Senior Web Engineer at Avaso Software Solutions / CNXION`,
    subtitle: `From April 2024, Remote`,
    desc: `
- Full-stack development for Avaso Bolt / CNXION platforms across backend and frontend. <span class="italic font-medium">[.NET, ASP.NET Core, Angular, PostgreSQL, MongoDB]</span><br>
- Designed and implemented features for the Avaso Bolt no-code platform, including reporting and tenant/module structure improvements.<br>
- Contributed to customs and trade workflows, including Customs Orders, Declarations, CBAM, and EUDR solutions.<br>
- Worked with customers and product leadership to design practical solutions such as CBAM XML reporting and the EUDR portal.<br>
- Improved platform maintainability through system upgrades, performance optimizations, and reliability enhancements.
  `,
  },
  {
    title: `Senior Web Engineer at NAPA Global`,
    subtitle: `From Sep 2023 to Mar 2024 at Da Nang, Vietnam`,
    desc: `
- Worked on integrated warehouse systems. <span class="italic font-medium">[.NET Core, Batch Script]</span><br>
- Collaborated with the project manager on Agile delivery, git branch management, code reviews, and solution design.
  `,
  },
  {
    title: `Senior Web Engineer at ERM System INC`,
    subtitle: `From Nov 2020 to Aug 2023 at Ho Chi Minh City, Vietnam`,
    desc: `
- Built multi-tenant systems following clean architecture principles. <span class="italic font-medium">[.NET Core, Angular, Clean Architecture]</span><br>
- Developed microservices-based solutions. <span class="italic font-medium">[Docker, Kubernetes, Helm]</span><br>
- Designed a reverse proxy for dynamic routing and SSL certificate management using Azure Key Vault. <span class="italic font-medium">[YARP, gRPC]</span><br>
- Built a dynamic form platform managed from the backend and integrated with automated submission handling. <span class="italic font-medium">[PostgreSQL, Redis Stream]</span><br>
- Implemented event-driven workflows and backend processing. <span class="italic font-medium">[Redis Stream, Message Broker]</span><br>
- Delivered features for lead management, property management, and property map search. <span class="italic font-medium">[PostgreSQL, Angular, NgRx]</span><br>
- Worked with Azure services including AKS, Blob Storage, Key Vault, Azure DevOps, and Git.
  `,
  },
  {
    title: `Freelance Developer`,
    subtitle: `From Mar 2018 to Dec 2021`,
    desc: `
- Built software for small businesses to support tracking, crawling, and product import workflows.<br>
<span class='text-gray-600 font-medium'>Skills: Selenium · .NET Framework</span>
  `,
  },
  {
    title: `Information Technology Help Desk at The People's Court of Quang Tri`,
    subtitle: `From Mar 2020 to Sep 2020 at Quang Tri, Vietnam`,
    desc: `
- Provided IT support for computers, printers, photocopy machines, and streaming systems.<br>
- Strengthened troubleshooting, operational support, and end-user assistance skills.
  `,
  },
  {
    title: `Junior Developer at Incredium`,
    subtitle: `From Dec 2018 to Mar 2020 at Hue, Vietnam`,
    desc: `
- Built Fire Click, a user behavior analytics product that tracks website activity and presents insights through tables, charts, heatmaps, and playback tools.<br>
<span class='text-gray-600 font-medium'>Skills: .NET MVC · JavaScript · Vue.js · Algorithms · Data Structures</span>
  `,
  },
  {
    title: `Intern Developer at HoaTamUs`,
    subtitle: `From Sep 2018 to Nov 2018 at Hue, Vietnam`,
    desc: `
- Implemented a self-drawing real estate map from polygon and point data, with zoom, scroll, and land information display features.<br>
<span class='text-gray-600 font-medium'>Skills: Algorithms · JavaScript · Data Structures</span>
  `,
  },
];
---

<BaseLayout title="CV">
  <div class="w-fit">
    <div
      class="w-1/3 sm:w-1/5 avatar transition ease-in-out w-1/2 hover:scale-[102%] block m-auto mt-3 mb-6"
    >
      <div>
        <img class="mask mask-circle" src="/knyl.jpg" alt="profile image" />
      </div>
    </div>
    <div class="text-center">
      <p class="font-medium text-2xl">Linh Duc Le</p>
      <p class="font-medium">Senior Web Engineer</p>
    </div>
  </div>

  <div class="my-5">
    Senior Web Engineer with 5+ years of experience across backend, frontend,
    and platform engineering. Strong in .NET, Angular, distributed systems,
    and building domain-heavy business platforms.
  </div>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Experience</div>
  </div>

  <div class="time-line-container mb-10">
    {
      arr.map((item) => (
        <TimeLineElement
          title={item.title}
          subtitle={item.subtitle}
          desc={item.desc}
        />
      ))
    }
  </div>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Education</div>
  </div>

  <div class="time-line-container grid gap-4 mb-10">
    <TimeLineElement
      title="Bachelor's degree, Information Technology"
      subtitle="2015 to 2019 at Hue University of Science, Hue, Vietnam"
      desc="Third Prize - The 2016 ACM ICPC Vietnam Central Provincial Contest."
    />
  </div>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Skills</div>
  </div>

  <ul class="list-disc md:columns-4 columns-2 mx-6">
    <li>.NET / ASP.NET Core</li>
    <li>Angular</li>
    <li>TypeScript</li>
    <li>JavaScript</li>
    <li>PostgreSQL</li>
    <li>MongoDB</li>
    <li>Distributed Systems</li>
    <li>Microservices</li>
    <li>Event-Driven Systems</li>
    <li>Docker</li>
    <li>Kubernetes</li>
    <li>Azure</li>
    <li>Git</li>
    <li>Azure DevOps</li>
    <li>GitHub Packages</li>
    <li>System Design</li>
  </ul>
</BaseLayout>